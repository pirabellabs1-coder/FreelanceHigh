// FreelanceHigh — Prisma Schema (Production)
// Source unique de verite pour tous les types DB

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ──

enum UserRole {
  FREELANCE
  CLIENT
  AGENCE
  ADMIN
}

enum UserPlan {
  GRATUIT
  PRO
  BUSINESS
  AGENCE
}

enum UserStatus {
  ACTIF
  SUSPENDU
  BANNI
}

enum ServiceStatus {
  BROUILLON
  EN_ATTENTE
  ACTIF
  PAUSE
  REFUSE
  VEDETTE
}

enum OrderStatus {
  EN_ATTENTE
  EN_COURS
  LIVRE
  REVISION
  TERMINE
  ANNULE
  LITIGE
}

enum EscrowStatus {
  HELD
  RELEASED
  DISPUTED
  REFUNDED
}

enum PaymentStatus {
  EN_ATTENTE
  COMPLETE
  ECHOUE
  REMBOURSE
}

enum PaymentMethod {
  CARTE
  MOBILE_MONEY
  VIREMENT
  PAYPAL
  STRIPE
}

enum DisputeStatus {
  OUVERT
  EN_EXAMEN
  RESOLU
}

enum DisputeVerdict {
  CLIENT
  FREELANCE
  PARTIEL
  ANNULATION
}

enum ConversationType {
  DIRECT
  GROUP
  ORDER
  ADMIN
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum NotificationType {
  ADMIN_ACTION
  MESSAGE
  ORDER
  KYC
  SYSTEM
  PAYMENT
}

enum KycStatus {
  EN_ATTENTE
  APPROUVE
  REFUSE
}

enum BlogStatus {
  BROUILLON
  PROGRAMME
  PUBLIE
}

enum BidStatus {
  EN_ATTENTE
  ACCEPTE
  REFUSE
  EXPIRE
}

enum ContractStatus {
  BROUILLON
  ENVOYE
  SIGNE
  EXPIRE
  ANNULE
}

enum AutomationStatus {
  ACTIF
  PAUSE
  BROUILLON
}

// ── Models ──

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  emailVerified   DateTime?
  passwordHash    String
  name            String
  image           String?
  role            UserRole   @default(FREELANCE)
  plan            UserPlan   @default(GRATUIT)
  status          UserStatus @default(ACTIF)
  country         String?
  countryFlag     String?
  avatar          String?
  kyc             Int        @default(1)
  suspendReason   String?

  // 2FA
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?

  // Formations
  formationsRole   String?  // "apprenant" ou "instructeur"

  // Tracking
  lastLoginAt     DateTime?
  lastLoginIp     String?
  loginCount      Int        @default(0)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  accounts           Account[]
  sessions           Session[]
  auditLogsAsActor   AuditLog[]          @relation("AuditActor")
  auditLogsAsTarget  AuditLog[]          @relation("AuditTarget")
  messages           Message[]
  notifications      Notification[]
  conversationUsers  ConversationUser[]
  loginAttempts      LoginAttempt[]
  freelancerProfile  FreelancerProfile?
  clientProfile      ClientProfile?
  agencyProfile      AgencyProfile?
  services           Service[]
  ordersAsClient     Order[]             @relation("OrderClient")
  ordersAsFreelance  Order[]             @relation("OrderFreelance")
  reviewsGiven       Review[]            @relation("ReviewAuthor")
  reviewsReceived    Review[]            @relation("ReviewTarget")
  paymentsAsPayer    Payment[]           @relation("PaymentPayer")
  paymentsAsPayee    Payment[]           @relation("PaymentPayee")
  bids               Bid[]
  contractsSigned    ContractSignature[]
  automations        AutomationScenario[]
  affiliationCodes   AffiliationCode[]
  blogPosts          BlogPost[]
  kycRequests        KycRequest[]
  disputesAsClient   Dispute[]           @relation("DisputeClient")
  disputesAsFreelance Dispute[]          @relation("DisputeFreelance")

  // Relations formations
  instructeurProfile InstructeurProfile?
  enrollments        Enrollment[]        @relation("UserEnrollments")
  certificates       Certificate[]       @relation("UserCertificates")
  formationReviews   FormationReview[]   @relation("UserFormationReviews")
  cartItems          CartItem[]          @relation("UserCartItems")
  productPurchases   DigitalProductPurchase[] @relation("UserProductPurchases")
  productReviews     DigitalProductReview[]   @relation("UserProductReviews")
  abandonedCarts     AbandonedCart[]          @relation("UserAbandonedCarts")
  marketingEvents    MarketingEvent[]         @relation("UserMarketingEvents")
  courseDiscussions   CourseDiscussion[]       @relation("UserDiscussions")
  discussionReplies  CourseDiscussionReply[]  @relation("UserDiscussionReplies")
  cohortMessages     CohortMessage[]         @relation("UserCohortMessages")

  @@index([email])
  @@index([role])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model FreelancerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?  @db.Text
  title       String?
  skills      String[] @default([])
  hourlyRate  Float?
  availability String? // "disponible", "occupe", "vacances"
  timezone    String?
  languages   String[] @default([])
  portfolio   Json?    // Array d'objets { title, description, imageUrl, link }
  badges      String[] @default([])
  completionRate Float @default(0)
  avgResponseTime Int? // en minutes

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  company     String?
  sector      String?
  size        String?  // "1-10", "11-50", "51-200", "200+"
  website     String?
  description String?  @db.Text

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgencyProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  agencyName  String
  logo        String?
  sector      String?
  size        String?
  description String?  @db.Text
  website     String?
  siret       String?
  verified    Boolean  @default(false)
  teamMembers Json?    // Array d'objets { userId, role, joinedAt }

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id              String   @id @default(cuid())
  userId          String
  token           String   @unique
  ipAddress       String?
  userAgent       String?
  expiresAt       DateTime
  isImpersonation Boolean  @default(false)
  impersonatedBy  String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String?
  color       String?
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  parentId    String?
  parent      Category? @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  services    Service[]
  tags        Tag[]
  createdAt   DateTime @default(now())

  @@index([slug])
  @@index([order])
}

enum MediaType {
  IMAGE
  VIDEO
}

model Service {
  id                   String        @id @default(cuid())
  title                String
  slug                 String        @unique
  language             String        @default("fr")
  description          Json?         // Format Tiptap JSON
  descriptionText      String?       @db.Text // Texte brut pour la recherche FTS
  categoryId           String
  subCategoryId        String?
  userId               String
  agencyId             String?
  status               ServiceStatus @default(BROUILLON)
  basePrice            Float         @default(5)
  deliveryDays         Int           @default(7)
  revisions            Int           @default(1)
  instructionsRequired Boolean       @default(false)
  instructionsContent  Json?         // Format Tiptap JSON
  draftData            Json?         // Sauvegarde brouillon wizard complet
  draftStep            Int?          // Derniere etape completee du wizard

  // Ancien champ prix conserve pour compatibilite
  price                Float         @default(5)

  // Legacy fields (migration progressive)
  tags                 String[]      @default([])
  images               String[]      @default([])
  packages             Json?
  faq                  Json?
  extras               Json?

  // Stats
  views                Int           @default(0)
  orderCount           Int           @default(0)
  rating               Float         @default(0)
  ratingCount          Int           @default(0)
  isBoosted            Boolean       @default(false)
  boostedUntil         DateTime?
  refuseReason         String?

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Relations
  category             Category      @relation(fields: [categoryId], references: [id])
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders               Order[]
  reviews              Review[]
  options              ServiceOption[]
  media                ServiceMedia[]
  serviceTags          ServiceTag[]

  @@index([slug])
  @@index([categoryId])
  @@index([userId])
  @@index([status])
  @@index([rating])
  @@index([agencyId])
}

model ServiceOption {
  id                  String   @id @default(cuid())
  serviceId           String
  title               String
  description         String?
  extraPrice          Float    @default(0)
  extraDays           Int      @default(0)
  isRecommended       Boolean  @default(false)
  sortOrder           Int      @default(0)
  expressEnabled      Boolean  @default(false)
  expressPrice        Float?
  expressDaysReduction Int?

  createdAt           DateTime @default(now())

  service             Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([sortOrder])
}

model ServiceMedia {
  id          String    @id @default(cuid())
  serviceId   String
  type        MediaType @default(IMAGE)
  url         String
  isPrimary   Boolean   @default(false)
  sortOrder   Int       @default(0)
  width       Int?
  height      Int?

  createdAt   DateTime  @default(now())

  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([isPrimary])
}

model Tag {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  categoryId  String?

  category    Category?    @relation(fields: [categoryId], references: [id])
  services    ServiceTag[]

  @@index([categoryId])
  @@index([slug])
}

model ServiceTag {
  serviceId   String
  tagId       String

  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tag         Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([serviceId, tagId])
  @@index([tagId])
}

model Order {
  id            String       @id @default(cuid())
  serviceId     String
  clientId      String
  freelanceId   String
  status        OrderStatus  @default(EN_ATTENTE)
  escrowStatus  EscrowStatus @default(HELD)
  amount        Float
  commission    Float        @default(0)
  packageType   String?      // "basic", "standard", "premium"
  requirements  String?      @db.Text
  deadline      DateTime
  deliveredAt   DateTime?
  completedAt   DateTime?
  progress      Int          @default(0)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  service       Service      @relation(fields: [serviceId], references: [id])
  client        User         @relation("OrderClient", fields: [clientId], references: [id])
  freelance     User         @relation("OrderFreelance", fields: [freelanceId], references: [id])
  payments      Payment[]
  reviews       Review[]
  disputes      Dispute[]
  conversation  Conversation?

  @@index([clientId])
  @@index([freelanceId])
  @@index([status])
  @@index([createdAt])
}

model Review {
  id          String   @id @default(cuid())
  orderId     String
  serviceId   String
  authorId    String
  targetId    String
  rating      Float
  comment     String?  @db.Text
  response    String?  @db.Text // reponse du freelance
  quality     Float?
  communication Float?
  timeliness  Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order       Order    @relation(fields: [orderId], references: [id])
  service     Service  @relation(fields: [serviceId], references: [id])
  author      User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  target      User     @relation("ReviewTarget", fields: [targetId], references: [id])

  @@unique([orderId, authorId])
  @@index([targetId])
  @@index([serviceId])
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String?
  payerId         String
  payeeId         String?
  amount          Float
  currency        String        @default("EUR")
  status          PaymentStatus @default(EN_ATTENTE)
  method          PaymentMethod?
  stripePaymentId String?
  description     String?
  type            String        @default("paiement") // paiement, commission, retrait, remboursement, abonnement

  createdAt       DateTime      @default(now())

  order           Order?        @relation(fields: [orderId], references: [id])
  payer           User          @relation("PaymentPayer", fields: [payerId], references: [id])
  payee           User?         @relation("PaymentPayee", fields: [payeeId], references: [id])

  @@index([orderId])
  @@index([payerId])
  @@index([payeeId])
  @@index([status])
}

model Dispute {
  id              String         @id @default(cuid())
  orderId         String
  clientId        String
  freelanceId     String
  reason          String
  clientArgument  String?        @db.Text
  freelanceArgument String?      @db.Text
  status          DisputeStatus  @default(OUVERT)
  verdict         DisputeVerdict?
  verdictNote     String?
  partialPercent  Int?
  resolvedAt      DateTime?

  createdAt       DateTime       @default(now())

  order           Order          @relation(fields: [orderId], references: [id])
  client          User           @relation("DisputeClient", fields: [clientId], references: [id])
  freelance       User           @relation("DisputeFreelance", fields: [freelanceId], references: [id])

  @@index([status])
  @@index([orderId])
}

model Bid {
  id          String    @id @default(cuid())
  userId      String
  projectId   String?   // reference a un projet client (future table)
  proposal    String?   @db.Text
  amount      Float
  deliveryDays Int
  status      BidStatus @default(EN_ATTENTE)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Contract {
  id          String         @id @default(cuid())
  title       String
  content     String         @db.Text
  orderId     String?
  status      ContractStatus @default(BROUILLON)
  expiresAt   DateTime?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  signatures  ContractSignature[]
}

model ContractSignature {
  id          String   @id @default(cuid())
  contractId  String
  userId      String
  signedAt    DateTime @default(now())
  ipAddress   String?

  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@unique([contractId, userId])
}

model AutomationScenario {
  id            String           @id @default(cuid())
  userId        String
  name          String
  trigger       String           // "order_accepted", "deadline_24h", "client_inactive_3d"
  conditions    Json?            // conditions supplementaires
  actions       Json             // actions a executer
  status        AutomationStatus @default(BROUILLON)
  planRequired  UserPlan         @default(PRO) // plan minimum requis
  executionCount Int             @default(0)
  lastExecutedAt DateTime?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AffiliationCode {
  id          String   @id @default(cuid())
  userId      String
  code        String   @unique
  commission  Float    @default(10) // pourcentage
  tier        String   @default("standard") // standard, premium
  usageCount  Int      @default(0)
  totalEarned Float    @default(0)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
}

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  content     String     @db.Text
  excerpt     String?
  coverImage  String?
  category    String?
  tags        String[]   @default([])
  authorId    String
  status      BlogStatus @default(BROUILLON)
  publishedAt DateTime?
  scheduledAt DateTime?
  views       Int        @default(0)

  // SEO
  metaTitle       String?
  metaDescription String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  author      User       @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([authorId])
}

model KycRequest {
  id              String    @id @default(cuid())
  userId          String
  requestedLevel  Int
  currentLevel    Int
  documentType    String
  documentUrl     String?
  status          KycStatus @default(EN_ATTENTE)
  reviewedBy      String?
  reviewedAt      DateTime?
  refuseReason    String?

  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorId       String
  action        String
  targetUserId  String?
  details       Json?
  ipAddress     String?

  createdAt     DateTime @default(now())

  actor         User     @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser    User?    @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}

model Conversation {
  id        String           @id @default(cuid())
  type      ConversationType @default(DIRECT)
  title     String?
  orderId   String?          @unique

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  order     Order?           @relation(fields: [orderId], references: [id])
  users     ConversationUser[]
  messages  Message[]

  @@index([type])
}

model ConversationUser {
  conversationId String
  userId         String
  lastReadAt     DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  senderId        String
  content         String       @db.Text
  type            MessageType  @default(TEXT)
  fileName        String?
  fileUrl         String?

  createdAt       DateTime     @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  read      Boolean          @default(false)
  link      String?

  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  ipAddress String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

// ══════════════════════════════════════════════════════════════
// FORMATIONS PLATFORM
// ══════════════════════════════════════════════════════════════

// ── Enums formations ──

enum FormationLevel {
  DEBUTANT
  INTERMEDIAIRE
  AVANCE
  TOUS_NIVEAUX
}

enum LessonType {
  VIDEO
  PDF
  TEXTE
  AUDIO
  QUIZ
}

enum QuestionType {
  CHOIX_UNIQUE
  CHOIX_MULTIPLE
  VRAI_FAUX
  TEXTE_LIBRE
}

enum FormationStatus {
  BROUILLON
  EN_ATTENTE
  ACTIF
  ARCHIVE
}

enum CohortStatus {
  OUVERT
  COMPLET
  EN_COURS
  TERMINE
  ANNULE
}

enum InstructeurStatus {
  EN_ATTENTE
  APPROUVE
  SUSPENDU
}

// ── Models formations ──

model FormationCategory {
  id        String   @id @default(cuid())
  nameFr    String
  nameEn    String
  slug      String   @unique
  icon      String?
  color     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)

  formations      Formation[]
  digitalProducts DigitalProduct[] @relation("CategoryProducts")

  createdAt DateTime @default(now())

  @@index([slug])
  @@index([order])
}

model InstructeurProfile {
  id          String            @id @default(cuid())
  userId      String            @unique
  bioFr       String?           @db.Text
  bioEn       String?           @db.Text
  expertise   String[]          @default([])
  linkedin    String?
  website     String?
  youtube     String?
  motivation  String?           @db.Text
  yearsExp    Int               @default(0)
  totalEarned Float             @default(0)
  status      InstructeurStatus @default(EN_ATTENTE)

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  formations       Formation[]
  withdrawals      InstructorWithdrawal[] @relation("InstructeurWithdrawals")
  digitalProducts  DigitalProduct[]  @relation("InstructeurProducts")
  marketingPixels  MarketingPixel[]  @relation("InstructeurPixels")

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status])
  @@index([userId])
}

model Formation {
  id              String          @id @default(cuid())
  slug            String          @unique

  // Bilingue
  titleFr         String
  titleEn         String
  shortDescFr     String?
  shortDescEn     String?
  descriptionFr   String?         @db.Text
  descriptionEn   String?         @db.Text
  learnPointsFr   String[]        @default([])
  learnPointsEn   String[]        @default([])
  requirementsFr  String[]        @default([])
  requirementsEn  String[]        @default([])
  targetAudienceFr String?        @db.Text
  targetAudienceEn String?        @db.Text

  // Médias
  thumbnail       String?
  previewVideo    String?

  // Catégorie
  categoryId      String
  subCategory     String?

  // Infos
  level           FormationLevel  @default(TOUS_NIVEAUX)
  language        String[]        @default(["fr"])
  duration        Int             @default(0) // minutes total

  // Prix
  price           Float           @default(0)
  originalPrice   Float?
  isFree          Boolean         @default(false)

  // Certificat
  hasCertificate  Boolean         @default(true)
  minScore        Int             @default(80)
  requireFinalQuiz Boolean        @default(false)

  // Stock limité & Promotions flash
  maxStudents     Int?            // null = illimité
  discountStartAt DateTime?
  discountEndAt   DateTime?
  descriptionFormat String        @default("text") // "text" | "tiptap"

  // Cohortes
  isGroupFormation Boolean        @default(false)

  // Stats
  studentsCount   Int             @default(0)
  rating          Float           @default(0)
  reviewsCount    Int             @default(0)
  viewsCount      Int             @default(0)

  // Statut
  status          FormationStatus @default(BROUILLON)
  publishedAt     DateTime?
  scheduledAt     DateTime?
  refuseReason    String?

  // Wizard brouillon
  draftStep       Int?

  // Relations
  instructeurId   String
  instructeur     InstructeurProfile @relation(fields: [instructeurId], references: [id])
  category        FormationCategory   @relation(fields: [categoryId], references: [id])
  sections        Section[]
  enrollments     Enrollment[]
  reviews         FormationReview[]
  cartItems       CartItem[]
  flashPromotions FlashPromotion[]    @relation("FormationFlashPromos")
  marketingEvents MarketingEvent[]    @relation("FormationMarketingEvents")
  discussions     CourseDiscussion[]
  cohorts         FormationCohort[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([instructeurId])
  @@index([status])
  @@index([rating])
  @@index([createdAt])
}

model Section {
  id          String    @id @default(cuid())
  titleFr     String
  titleEn     String
  descFr      String?
  descEn      String?
  order       Int       @default(0)
  formationId String
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  @@index([formationId, order])
}

model Lesson {
  id              String     @id @default(cuid())
  titleFr         String
  titleEn         String
  descFr          String?    @db.Text
  descEn          String?    @db.Text
  type            LessonType @default(VIDEO)
  content         String?    @db.Text // Pour les leçons TEXTE (HTML rich text)
  videoUrl        String?    // URL YouTube/Vimeo ou URL signée Supabase
  videoStoragePath String?   // Chemin dans Supabase Storage
  pdfUrl          String?
  pdfStoragePath  String?
  audioUrl         String?
  audioStoragePath String?
  subtitleUrl      String?    // URL publique du fichier .vtt
  subtitleStoragePath String? // Chemin dans Supabase Storage
  subtitleLabel    String?    // Ex: "Français", "English"
  chapters         Json?      // [{title, timestamp}] pour navigation vidéo
  duration         Int?       // minutes
  order            Int        @default(0)
  isFree           Boolean    @default(false)
  allowDownload    Boolean    @default(false) // pour PDF/audio
  sectionId        String
  section          Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  resources        LessonResource[]
  quiz             Quiz?
  progress         LessonProgress[]

  @@index([sectionId, order])
}

model LessonResource {
  id          String   @id @default(cuid())
  lessonId    String
  name        String
  url         String
  fileSize    Int?     // bytes
  mimeType    String?
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Quiz {
  id           String     @id @default(cuid())
  titleFr      String
  titleEn      String
  passingScore Int        @default(80)
  timeLimit    Int?       // minutes, null = pas de limite
  lessonId     String     @unique
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions    Question[]

  @@index([lessonId])
}

model Question {
  id            String       @id @default(cuid())
  textFr        String       @db.Text
  textEn        String       @db.Text
  type          QuestionType @default(CHOIX_UNIQUE)
  options       Json         // Array of { textFr, textEn, value }
  correctAnswer String       // valeur(s) correcte(s) — JSON array pour CHOIX_MULTIPLE
  explanationFr String?      @db.Text
  explanationEn String?      @db.Text
  order         Int          @default(0)
  quizId        String
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, order])
}

model Enrollment {
  id              String          @id @default(cuid())
  userId          String
  formationId     String
  cohortId        String?
  progress        Float           @default(0) // 0-100%
  completedAt     DateTime?
  paidAmount      Float           @default(0)
  stripeSessionId String?
  refundRequested Boolean         @default(false)
  refundReason    String?
  refundedAt      DateTime?

  user            User            @relation("UserEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  formation       Formation       @relation(fields: [formationId], references: [id])
  cohort          FormationCohort? @relation(fields: [cohortId], references: [id])
  lessonProgress  LessonProgress[]
  certificate     Certificate?
  notes           LessonNote[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([userId, formationId])
  @@index([userId])
  @@index([formationId])
  @@index([cohortId])
  @@index([createdAt])
}

model LessonProgress {
  id           String     @id @default(cuid())
  enrollmentId String
  lessonId     String
  completed    Boolean    @default(false)
  score        Int?       // score quiz 0-100
  watchedPct   Float?     // pourcentage visionné pour les vidéos
  completedAt  DateTime?
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
}

model LessonNote {
  id           String     @id @default(cuid())
  enrollmentId String
  lessonId     String
  content      String     @db.Text
  timestamp    Int?       // secondes dans la vidéo
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, lessonId])
}

model Certificate {
  id           String     @id @default(cuid())
  code         String     @unique
  enrollmentId String     @unique
  userId       String
  formationId  String
  score        Int        @default(0)
  pdfUrl       String?
  pdfStoragePath String?
  revokedAt    DateTime?
  revokeReason String?
  issuedAt     DateTime   @default(now())

  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  user         User       @relation("UserCertificates", fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
  @@index([formationId])
}

model FormationReview {
  id          String    @id @default(cuid())
  rating      Int       // 1-5
  comment     String    @db.Text
  userId      String
  formationId String
  enrollmentId String?
  response    String?   @db.Text
  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation("UserFormationReviews", fields: [userId], references: [id], onDelete: Cascade)
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@unique([userId, formationId])
  @@index([formationId])
  @@index([userId])
}

model CartItem {
  id          String    @id @default(cuid())
  userId      String
  formationId String
  createdAt   DateTime  @default(now())

  user        User      @relation("UserCartItems", fields: [userId], references: [id], onDelete: Cascade)
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@unique([userId, formationId])
  @@index([userId])
}

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  discountPct   Int      // 0-100
  maxUsage      Int?     // null = illimité
  usageCount    Int      @default(0)
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  formationIds  String[] @default([]) // vide = tous les cours

  createdAt     DateTime @default(now())

  @@index([code])
}

model InstructorWithdrawal {
  id            String    @id @default(cuid())
  instructeurId String
  amount        Float
  method        String    // "virement", "paypal", "wave", "orange_money", "mtn"
  accountDetails Json     // IBAN, email PayPal, numéro mobile...
  status        String    @default("EN_ATTENTE") // EN_ATTENTE, TRAITE, REFUSE
  refusedReason String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  instructeur   InstructeurProfile @relation("InstructeurWithdrawals", fields: [instructeurId], references: [id], onDelete: Cascade)

  @@index([instructeurId])
  @@index([status])
}

// ── Enums produits numériques & marketing ──

enum DigitalProductType {
  EBOOK
  PDF
  TEMPLATE
  LICENCE
  AUDIO
  VIDEO
  AUTRE
}

enum DigitalProductStatus {
  BROUILLON
  EN_ATTENTE
  ACTIF
  ARCHIVE
  REFUSE
}

enum PixelType {
  FACEBOOK
  GOOGLE
  TIKTOK
}

enum MarketingEventType {
  PAGE_VIEW
  ADD_TO_CART
  CHECKOUT_STARTED
  PURCHASE_COMPLETED
  PAYMENT_FAILED
  CART_ABANDONED
}

enum AbandonedCartStatus {
  DETECTE
  RELANCE_1
  RELANCE_2
  RELANCE_3
  CONVERTI
  TERMINE
  DESABONNE
}

// ── Produits Numériques ──

model DigitalProduct {
  id                String               @id @default(cuid())
  slug              String               @unique

  // Bilingue
  titleFr           String
  titleEn           String
  descriptionFr     String?              @db.Text
  descriptionEn     String?              @db.Text
  descriptionFormat String               @default("text") // "text" | "tiptap"

  // Type de produit
  productType       DigitalProductType   @default(EBOOK)

  // Médias
  banner            String?              // URL image bannière/couverture
  fileUrl           String?              // URL Supabase Storage
  fileStoragePath   String?              // chemin dans le bucket
  fileSize          Int?                 // bytes
  fileMimeType      String?

  // Aperçu
  previewEnabled    Boolean              @default(false)
  previewPages      Int                  @default(5) // nombre de pages pour l'aperçu PDF
  watermarkEnabled  Boolean              @default(true)

  // Prix
  price             Float                @default(0)
  originalPrice     Float?
  isFree            Boolean              @default(false)

  // Stock limité
  maxBuyers         Int?                 // null = illimité
  currentBuyers     Int                  @default(0)

  // Stats
  rating            Float                @default(0)
  reviewsCount      Int                  @default(0)
  salesCount        Int                  @default(0)
  viewsCount        Int                  @default(0)

  // Tags
  tags              String[]             @default([])

  // Statut
  status            DigitalProductStatus @default(BROUILLON)
  refuseReason      String?

  // Relations
  instructeurId     String
  categoryId        String
  instructeur       InstructeurProfile   @relation("InstructeurProducts", fields: [instructeurId], references: [id])
  category          FormationCategory    @relation("CategoryProducts", fields: [categoryId], references: [id])
  purchases         DigitalProductPurchase[]
  reviews           DigitalProductReview[]
  flashPromotions   FlashPromotion[]     @relation("ProductFlashPromos")
  marketingEvents   MarketingEvent[]     @relation("ProductMarketingEvents")

  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([slug])
  @@index([instructeurId])
  @@index([categoryId])
  @@index([status])
  @@index([productType])
  @@index([rating])
  @@index([createdAt])
}

model DigitalProductPurchase {
  id              String         @id @default(cuid())
  userId          String
  productId       String
  paidAmount      Float          @default(0)
  stripeSessionId String?
  licenseKey      String?        // clé de licence unique si type LICENCE
  downloadCount   Int            @default(0)
  maxDownloads    Int            @default(5)

  user            User           @relation("UserProductPurchases", fields: [userId], references: [id], onDelete: Cascade)
  product         DigitalProduct @relation(fields: [productId], references: [id])

  createdAt       DateTime       @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@index([stripeSessionId])
}

model DigitalProductReview {
  id          String         @id @default(cuid())
  rating      Int            // 1-5
  comment     String         @db.Text
  userId      String
  productId   String
  response    String?        @db.Text // réponse de l'instructeur
  respondedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User           @relation("UserProductReviews", fields: [userId], references: [id], onDelete: Cascade)
  product     DigitalProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}

// ── Promotions Flash ──

model FlashPromotion {
  id               String          @id @default(cuid())
  formationId      String?
  digitalProductId String?
  discountPct      Int             // 1-90
  startsAt         DateTime
  endsAt           DateTime
  maxUsage         Int?            // null = illimité
  usageCount       Int             @default(0)
  isActive         Boolean         @default(true)

  formation        Formation?      @relation("FormationFlashPromos", fields: [formationId], references: [id], onDelete: Cascade)
  digitalProduct   DigitalProduct? @relation("ProductFlashPromos", fields: [digitalProductId], references: [id], onDelete: Cascade)

  createdAt        DateTime        @default(now())

  @@index([formationId])
  @@index([digitalProductId])
  @@index([isActive, endsAt])
}

// ── Paniers Abandonnés ──

model AbandonedCart {
  id            String              @id @default(cuid())
  userId        String
  cartItemIds   String[]            @default([])
  detectedAt    DateTime            @default(now())
  emailSequence Int                 @default(0) // 0=pas envoyé, 1=1h, 2=24h, 3=7j
  lastEmailAt   DateTime?
  status        AbandonedCartStatus @default(DETECTE)

  user          User                @relation("UserAbandonedCarts", fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime            @default(now())

  @@index([userId])
  @@index([status])
  @@index([detectedAt])
}

// ── Marketing Pixels ──

model MarketingPixel {
  id            String             @id @default(cuid())
  instructeurId String
  type          PixelType
  pixelId       String             // ID du pixel (ex: "123456789012345" pour Facebook)
  isActive      Boolean            @default(true)

  instructeur   InstructeurProfile @relation("InstructeurPixels", fields: [instructeurId], references: [id], onDelete: Cascade)

  createdAt     DateTime           @default(now())

  @@unique([instructeurId, type])
  @@index([instructeurId])
}

// ── Marketing Events ──

model MarketingEvent {
  id               String             @id @default(cuid())
  type             MarketingEventType
  formationId      String?
  digitalProductId String?
  userId           String?
  metadata         Json?

  formation        Formation?         @relation("FormationMarketingEvents", fields: [formationId], references: [id], onDelete: SetNull)
  digitalProduct   DigitalProduct?    @relation("ProductMarketingEvents", fields: [digitalProductId], references: [id], onDelete: SetNull)
  user             User?              @relation("UserMarketingEvents", fields: [userId], references: [id], onDelete: SetNull)

  createdAt        DateTime           @default(now())

  @@index([type, createdAt])
  @@index([formationId])
  @@index([digitalProductId])
  @@index([userId])
}

// ── Course Discussions ──

model CourseDiscussion {
  id          String   @id @default(cuid())
  formationId String
  userId      String
  title       String
  content     String   @db.Text
  isPinned    Boolean  @default(false)
  isResolved  Boolean  @default(false)

  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)
  user        User      @relation("UserDiscussions", fields: [userId], references: [id], onDelete: Cascade)
  replies     CourseDiscussionReply[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([formationId, createdAt])
  @@index([userId])
}

model CourseDiscussionReply {
  id           String @id @default(cuid())
  discussionId String
  userId       String
  content      String @db.Text
  isInstructor Boolean @default(false)

  discussion   CourseDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User             @relation("UserDiscussionReplies", fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())

  @@index([discussionId, createdAt])
  @@index([userId])
}

// ── Cohortes (Formations groupées) ──

model FormationCohort {
  id                String       @id @default(cuid())
  formationId       String

  // Bilingue
  titleFr           String
  titleEn           String
  descriptionFr     String?      @db.Text
  descriptionEn     String?      @db.Text

  // Dates
  startDate         DateTime
  endDate           DateTime
  enrollmentDeadline DateTime
  durationDays      Int

  // Capacité
  maxParticipants   Int
  currentCount      Int          @default(0)

  // Prix
  price             Float
  originalPrice     Float?

  // Statut
  status            CohortStatus @default(OUVERT)

  // Programme semaine par semaine (JSON)
  schedule          Json?

  // Relations
  formation         Formation    @relation(fields: [formationId], references: [id], onDelete: Cascade)
  enrollments       Enrollment[]
  messages          CohortMessage[]

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([formationId])
  @@index([status])
  @@index([startDate])
  @@index([enrollmentDeadline])
}

model CohortMessage {
  id             String          @id @default(cuid())
  cohortId       String
  userId         String
  content        String          @db.Text
  isInstructor   Boolean         @default(false)
  isPinned       Boolean         @default(false)
  attachmentUrl  String?
  attachmentName String?

  cohort         FormationCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user           User            @relation("UserCohortMessages", fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([cohortId, createdAt])
  @@index([userId])
  @@index([cohortId, isPinned])
}
